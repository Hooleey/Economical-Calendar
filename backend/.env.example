# Optional: Neon / PostgreSQL (Render, etc.). If unset, local SQLite (events.db) is used.
# DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require

# External source page for HTML parsing
ALFAFOREX_PAGE_URL=https://alfaforex.ru/economic-calendar/

# Refresh interval for backend auto-sync (seconds)
ALFAFOREX_SYNC_TTL_SECONDS=300

# News RSS aggregate: min seconds between soft refreshes triggered by GET /news
NEWS_SYNC_TTL_SECONDS=900
